domain-needed
bogus-priv
no-resolv
{% if ansible_facts["hostname"] in groups["dns-master"] %}
{% for dns in dnsmasq.upstream_dns %}
server={{ dns }}
{% endfor %}
{% endif %}
{% if ansible_facts["hostname"] in groups["dns-slave"] %}
server={{ groups("dns-master")[0] }}
server=/{{ dnsmasq.domain }}/{{ groups("dns-master")[0] }}
{% endif %}
local=/{{ dnsmasq.domain }}/
listen-address=127.0.0.1,::1,{{ ansible_default_ipv4.address }}
interface={{ dnsmasq.interface }}
expand-hosts
domain={{ dnsmasq.domain }}

{% if ansible_facts["hostname"] in groups["dns-master"] %}
dhcp-range={{ dnsmasq.range_start }},{{ dnsmasq.range_end }},{{ dnsmasq.lease_time }}

dhcp-option=option:router,{{ dnsmasq.gateway }}
dhcp-authoritative
dhcp-leasefile=/var/lib/dnsmasq/dnsmasq.leases
{% endif %}

log-dhcp
log-queries
log-facility=/var/log/dnsmasq.log
